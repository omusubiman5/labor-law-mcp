# ============================================================
# OAuth 認証 (audiobook-mcp / health-mcp と同じ Auth0 ベース)
# ============================================================

# このサーバーの公開 URL (Vercel デプロイ後の URL)
SERVER_URL=https://labor-law-mcp.vercel.app

# Auth0 テナント設定（Auth0 ダッシュボードから取得）
# Auth0 は Google Workspace OIDC を upstream IdP として使う想定
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://mcp-servers

# 内部 JWT 署名鍵 (32 byte 以上の random string、`openssl rand -base64 32` で生成)
OAUTH_SECRET=replace_me_with_random_secret

# 認可するユーザーのメールアドレス（カンマ区切り。空にすると全員許可）
ALLOWED_EMAILS=omusubiman@gmail.com
